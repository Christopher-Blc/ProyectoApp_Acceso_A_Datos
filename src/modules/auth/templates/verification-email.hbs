<!doctype html>
<html lang="es" style="margin:0;padding:0;">
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verifica tu cuenta ResPi</title>
  </head>
  <body style="margin:0;padding:0;background-color:#eef1f4;font-family:Arial,Helvetica,sans-serif;color:#2c3e50;">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background-color:#eef1f4;margin:0;padding:24px 12px;">
      <tr>
        <td align="center">
          <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="max-width:600px;background-color:#ffffff;border-radius:14px;overflow:hidden;">
            <tr>
              <td style="background-color:#2c3e50;padding:20px 24px;text-align:center;">
                <p style="margin:0;font-size:24px;line-height:1.2;font-weight:bold;color:#ffffff;">ResPi</p>
                <p style="margin:8px 0 0;font-size:13px;line-height:1.4;color:#d9e2ec;">Confirma tu correo para activar tu cuenta</p>
              </td>
            </tr>
            <tr>
              <td style="padding:24px;">
                <p style="margin:0 0 14px;font-size:20px;line-height:1.3;font-weight:bold;color:#2c3e50;">Hola {{userName}},</p>
                <p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#455a70;">Gracias por registrarte. Para poder iniciar sesion, necesitas confirmar tu direccion de correo electronico.</p>
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin:20px 0 18px;">
                  <tr>
                    <td align="center">
                      <a href="{{verifyUrl}}" style="display:inline-block;background-color:#ff4757;color:#ffffff;text-decoration:none;font-size:16px;line-height:1.2;font-weight:bold;padding:14px 24px;border-radius:10px;">Verificar cuenta</a>
                    </td>
                  </tr>
                </table>
                <p style="margin:0 0 8px;font-size:13px;line-height:1.6;color:#6b7b8c;">Si el boton no funciona, copia y pega este enlace en tu navegador:</p>
                <p style="margin:0 0 18px;font-size:13px;line-height:1.6;word-break:break-all;color:#ff4757;">{{verifyUrl}}</p>
                <p style="margin:0;font-size:13px;line-height:1.6;color:#6b7b8c;">Si no has creado esta cuenta, puedes ignorar este mensaje.</p>
              </td>
            </tr>
            <tr>
              <td style="background-color:#f4f6f8;padding:16px 24px;text-align:center;border-top:1px solid #e4e8ec;">
                <p style="margin:0 0 6px;font-size:12px;line-height:1.4;color:#708090;">ResPi · Ontinyent, Espana</p>
                <p style="margin:0;font-size:12px;line-height:1.4;color:#708090;">&copy; {{year}} ResPi. Todos los derechos reservados.</p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
