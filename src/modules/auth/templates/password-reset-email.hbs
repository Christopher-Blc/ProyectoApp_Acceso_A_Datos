<!doctype html>
<html lang="es" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="x-apple-disable-message-reformatting">
    <meta name="color-scheme" content="dark">
    <meta name="supported-color-schemes" content="dark">
    <title>ResPi</title>
    <style>
      :root {
        color-scheme: dark;
        supported-color-schemes: dark;
      }
      @media (prefers-color-scheme: dark) {
        .body { background-color: #000000 !important; }
        .card { background-color: #1a1a1a !important; }
      }
    </style>
  </head>
  <body class="body" style="margin:0;padding:0;background-color:#000000;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;-webkit-font-smoothing:antialiased;">
    
    <div style="background-color:#000000; color:#ffffff; font-size:15px;">
      <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background-color:#000000;">
        <tr>
          <td align="center" style="padding: 40px 10px;">
            
            <table class="card" role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="max-width:450px;background-color:#1a1a1a;border-radius:28px;border:1px solid #333333;overflow:hidden;">
              
              <tr>
                <td style="background-color:#1f1f1f;padding:32px 24px;text-align:center;border-bottom:1px solid rgba(245,202,126,0.2);">
                  <p style="margin:0;font-size:26px;line-height:1.2;font-weight:bold;color:#ffffff;">ResPi<span style="color:#F5CA7E;">.</span></p>
                  <p style="margin:8px 0 0;font-size:13px;line-height:1.4;color:#929293;">Recupera acceso a tu cuenta</p>
                </td>
              </tr>

              <tr>
                <td style="padding: 40px 40px; text-align:center;">
                  <h1 style="color:#ffffff; font-size:24px; font-weight:bold; margin:0 0 15px 0;">¡Hola, {{userName}}!</h1>
                  <p style="color:#bbbbbb; font-size:15px; line-height:1.6; margin:0 0 30px 0;">
                    Recibimos una solicitud para cambiar tu contraseña. Pulsa el botón de abajo para establecer una nueva contraseña en <span style="color:#F5CA7E; font-weight:bold;">ResPi</span>.
                  </p>

                  <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                    <tr>
                      <td align="center">
                        <a href="{{resetUrl}}" style="background-color:#F5CA7E; color:#000000; display:inline-block; padding:16px 32px; border-radius:50px; font-family:Arial, sans-serif; font-size:16px; font-weight:bold; text-decoration:none;">
                          Cambiar contraseña
                        </a>
                      </td>
                    </tr>
                  </table>

                  <div style="margin-top:40px; border-top:1px solid #333333; padding-top:20px;">
                    <p style="color:#666666; font-size:11px; margin-bottom:10px;">O copia este enlace:</p>
                    <p style="color:#F5CA7E; font-size:11px; word-break:break-all; opacity:0.7;">{{resetUrl}}</p>
                  </div>

                  <div style="margin-top:30px; padding:20px; background-color:#2a2a2a; border-radius:12px; border-left:4px solid #F5CA7E;">
                    <p style="color:#ffaa33; font-size:12px; margin:0; font-weight:bold;">⚠️ Atención</p>
                    <p style="color:#aaaaaa; font-size:11px; margin:8px 0 0 0; line-height:1.5;">Este enlace solo es válido durante 30 minutos. Si no intentaste cambiar tu contraseña, ignora este correo.</p>
                  </div>
                </td>
              </tr>

              <tr>
                <td style="background-color:#111111; padding:20px; text-align:center;">
                  <p style="color:#555555; font-size:10px; margin:0; text-transform:uppercase; letter-spacing:1px;">
                    ResPi · Ontinyent, España
                  </p>
                </td>
              </tr>
            </table>

            <p style="color:#444444; font-size:12px; margin-top:30px;">
              Si no fuiste tú, puedes ignorar este correo de forma segura.
            </p>

          </td>
        </tr>
      </table>
    </div>
  </body>
</html>
